{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:best-practices", ":disableDependencyDashboard"],
  "schedule": ["every monday after 9am and before 12pm"],  
  "packageRules": [
    {
      "matchFileNames": ["requirements.txt"],
      "enabled": false
    },
    {
      "matchManagers": ["github-actions"],
      "matchPackageNames": ["python"],
      "enabled": false
    },
    {
      "groupName": "Github Actions",
      "matchFileNames": [".github/workflows/*.yml"]
    },
    {
      "groupName": "Docker images",
      "matchFileNames": ["docker/*.dockerfile"]
    }
  ]
}